{
  "name": "saintrocky",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "@saintrocky/mobile/react",
      "@saintrocky/mobile/react-native",
      "@saintrocky/mobile/react-native/**"
    ]
  },
  "scripts": {
    "dev": "PORT=5175 NODE_ENV=development yarn workspace @saintrocky/web dev",
    "dev:web": "yarn workspace @saintrocky/web dev",
    "dev:api": "yarn workspace @saintrocky/api dev",
    "dev:worker": "yarn workspace @saintrocky/worker dev",
    "dev:mobile": "yarn workspace @saintrocky/mobile dev",
    "dev:electron": "yarn workspace @saintrocky/electron dev",
    "build": "yarn workspaces run build",
    "build:web": "yarn workspace @saintrocky/web build",
    "heroku-postbuild": "yarn workspace @saintrocky/web build",
    "start": "node server.mjs",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest -c jest.config.js",
    "lint": "eslint . && yarn workspaces run lint",
    "add:web": "yarn workspace @saintrocky/web add",
    "add:api": "yarn workspace @saintrocky/api add",
    "add:mobile": "yarn workspace @saintrocky/mobile add",
    "add:pkg": "node ./scripts/add-pkg.js",
    "set:project": "node ./scripts/set-project.mjs",
    "seed:users": "yarn workspace @saintrocky/api seed:users",
    "seed:rules": "yarn workspace @saintrocky/api seed:rules",
    "seed:blog": "yarn workspace @saintrocky/api seed:blog",
    "seed:wallets": "yarn workspace @saintrocky/api seed:wallets",
    "seed:social": "yarn workspace @saintrocky/api seed:social",
    "seed:all": "yarn workspace @saintrocky/api seed:all",
    "escrow:init": "node apps/blockchain/scripts/initialize-platform.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "jest": "^29.7.0"
  }
}


