# Env files are loaded from the workspace root in this order:
# 1. .env
# 2. .env.development or .env.production
# 3. .env.local
#
# Keep real secrets in .env.local (local dev) or in your deployment provider config.

APP_ENV=development

# Core runtime
MONGODB_URI=mongodb://localhost:27017/saintrocky
JWT_SECRET=change_me
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost
PUBLIC_API_URL=http://localhost:4000

# API CORS
# CORS_ALLOWED_ORIGINS controls which origins may call the API.
# Include web app origins plus exact chrome-extension:// origins when the extension
# talks directly to the API from the browser.
CORS_ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://your-extension-id

# AWS
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_S3_BUCKET=change_me
AWS_PUBLIC_BASE_URL=https://example-bucket.s3.amazonaws.com
AWS_MAX_UPLOAD_BYTES=10485760

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change_me
SMTP_PASS=change_me

# Public clients
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=Saint Rocky
EXPO_PUBLIC_PRODUCT_NAME=Standard Deviants
EXPO_PUBLIC_EAS_PROJECT_ID=change_me
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# EXTENSION_ALLOWED_ORIGINS controls which web origins are allowed to post
# auth handoff messages into the extension.
EXTENSION_API_BASE_URL=http://localhost:4000
EXTENSION_ALLOWED_ORIGINS=http://localhost:5173

ELECTRON_API_BASE_URL=http://localhost:4000
ELECTRON_RENDERER_URL=http://localhost:5174

# AI
HUGGINGFACE_API_KEY=change_me
HUGGINGFACE_CHAT_MODEL=change_me

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=http://localhost:8899
SOLANA_RPC_URL=http://localhost:8899
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=